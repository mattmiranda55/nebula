{
  "name": "nebula",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun run build:electron && concurrently -k -n renderer,main \"bun run dev:renderer\" \"bun run dev:main\"",
    "dev:renderer": "vite",
    "dev:main": "concurrently -k -n tsc,electron \"bun run watch:electron\" \"bun run start:electron\"",
    "watch:electron": "tsc -p tsconfig.electron.json --watch --preserveWatchOutput",
    "start:electron": "ELECTRON_RENDERER_URL=http://localhost:5173 bunx electronmon dist-electron/main.js --watch dist-electron --ignore config.toml",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build": "bun run build:electron && vue-tsc && vite build && electron-builder",
    "preview": "vite preview"
  },
  "dependencies": {
    "@primevue/themes": "^4.4.1",
    "better-sqlite3": "^12.4.6",
    "kerberos": "^7.0.0",
    "monaco-editor": "^0.55.1",
    "monaco-editor-vue3": "^1.0.4",
    "mongodb": "^7.0.0",
    "mysql2": "^3.15.3",
    "pg": "^8.16.3",
    "primeicons": "^7.0.0",
    "primevue": "^4.4.1",
    "vue": "^3.4.21"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.17",
    "@tailwindcss/vite": "^4.1.17",
    "@types/better-sqlite3": "^7.6.13",
    "@types/pg": "^8.15.6",
    "@vitejs/plugin-vue": "^5.0.4",
    "autoprefixer": "^10.4.22",
    "concurrently": "^8.2.2",
    "electron": "^30.0.1",
    "electron-builder": "^24.13.3",
    "electronmon": "^2.0.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.17",
    "typescript": "^5.2.2",
    "vite": "^5.1.6",
    "vue-tsc": "^2.0.26"
  },
  "main": "dist-electron/main.js"
}
