{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "nodenext",
    "outDir": "./dist-electron",
    "rootDir": "./electron",
    "noEmit": false,
    "isolatedModules": false,
    "types": ["node", "electron"],
    "declaration": false,
    "sourceMap": true,
    "allowImportingTsExtensions": false,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true
  },
  "include": [
    "electron/**/*.ts",
    "electron/**/*.cts"
  ],
  "exclude": [
    "electron/preload.ts"
  ]
}
